<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>ALL-STAR TEAM UP • Premium NBA 2K Tournaments</title>
    <script src="https://cdn.tailwindcss.com"></script>
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.5.1/css/all.min.css">
    <style>
        body { font-family: 'Inter', system_ui, sans-serif; }
        .font-display { font-family: 'Space Grotesk', 'Inter', sans-serif; font-weight: 600; }
        .season-card { transition: all 0.3s cubic-bezier(0.4, 0, 0.2, 1); }
        .season-card.active { border-color: #22d3ee; box-shadow: 0 0 0 1px #22d3ee; }
        .nav-scrolled { background-color: rgba(10, 10, 10, 0.95); backdrop-filter: blur(12px); }
    </style>
</head>
<body class="bg-[#0A0A0A] text-white">
    <!-- NAVBAR -->
    <nav id="navbar" class="fixed top-0 left-0 right-0 z-50 border-b border-white/10 transition-all">
        <div class="max-w-7xl mx-auto px-8">
            <div class="flex items-center justify-between py-5">
                <div class="flex items-center gap-x-3">
                    <div class="w-10 h-10 bg-cyan-400 rounded-xl flex items-center justify-center">
                        <i class="fa-solid fa-trophy text-[#0A0A0A] text-3xl"></i>
                    </div>
                    <div>
                        <span class="font-display text-2xl font-semibold tracking-tighter">ALL-STAR</span>
                        <span class="font-display text-2xl font-semibold tracking-tighter text-cyan-400">TEAM UP</span>
                    </div>
                </div>

                <div class="hidden md:flex items-center gap-x-8 text-sm font-medium">
                    <a href="#seasons" class="hover:text-cyan-400 transition-colors">Seasons</a>
                    <a href="#how" class="hover:text-cyan-400 transition-colors">How it Works</a>
                    <a href="#pricing" class="hover:text-cyan-400 transition-colors">Pricing</a>
                </div>

                <div class="flex items-center gap-x-4">
                    <a href="https://discord.gg/Tc6GG7sCR" target="_blank"
                       class="hidden sm:flex items-center gap-x-2 px-5 py-2.5 text-sm font-semibold bg-white/10 hover:bg-white/15 border border-white/20 rounded-2xl transition-all">
                        <i class="fa-brands fa-discord"></i>
                        <span>Join Discord</span>
                    </a>
                    <button onclick="document.getElementById('register-modal').showModal()"
