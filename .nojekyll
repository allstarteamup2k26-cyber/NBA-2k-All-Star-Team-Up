                    </div>
                    <div class="text-right">
                        <div class="text-6xl font-semibold tracking-tighter">$15</div>
                    </div>
                </div>
                <ul class="mt-8 space-y-3 text-sm">
                    <li class="flex gap-x-3"><i class="fa-solid fa-check text-emerald-400 mt-1"></i> Individual registration</li>
                    <li class="flex gap-x-3"><i class="fa-solid fa-check text-emerald-400 mt-1"></i> Access to all 3 tournaments</li>
                    <li class="flex gap-x-3"><i class="fa-solid fa-check text-emerald-400 mt-1"></i> Match notifications</li>
                </ul>
                <button onclick="selectPlan('solo')" 
                        class="mt-8 w-full py-4 border border-white/40 font-semibold rounded-2xl">Pay $15 — Solo Queue Entry</button>
            </div>
        </div>
    </div>

    <!-- RULES SUMMARY -->
    <div class="max-w-4xl mx-auto px-8 py-12 border-t border-white/10">
        <h3 class="font-display text-3xl tracking-tighter mb-6 text-center">Tournament Rules</h3>
        <div class="bg-zinc-900 border border-white/10 rounded-3xl p-8 text-sm space-y-5">
            <div class="grid md:grid-cols-2 gap-6">
                <div>
                    <div class="font-semibold mb-2">Format</div>
                    <p>Round Robin group stage → Double Elimination bracket</p>
                </div>
                <div>
                    <div class="font-semibold mb-2">Team Limits</div>
                    <p>Max 32 teams • Minimum 8 teams to start</p>
                </div>
                <div>
                    <div class="font-semibold mb-2">Locker Room</div>
                    <p>Team Captain creates private locker room and invites other captains. Captains then invite their team members.</p>
                </div>
                <div>
                    <div class="font-semibold mb-2">Prize Pool</div>
                    <p>1st $300 • 2nd $100 • 3rd $50 ($450 total)</p>
                </div>
