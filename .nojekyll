    <!-- CHOOSE YOUR TOURNAMENT -->
    <div class="max-w-6xl mx-auto px-8 py-16 border-t border-white/10">
        <div class="text-center mb-10">
            <div class="text-cyan-400 text-sm font-semibold tracking-[2px] mb-2">CHOOSE YOUR TOURNAMENT</div>
            <h2 class="font-display text-4xl tracking-tighter">Select Your Platform &amp; Game</h2>
        </div>

        <div class="grid md:grid-cols-3 gap-6">
            <a href="2k25-tournament.html" class="group block bg-zinc-900 border border-white/10 hover:border-cyan-400 rounded-3xl p-8 transition-all">
                <div class="font-semibold text-2xl mb-2 group-hover:text-cyan-400">2K25 Tournament</div>
